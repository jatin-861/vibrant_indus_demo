# Local-only file for `supabase functions serve --env-file supabase/functions/.env`.
# In production these are set with `supabase secrets set` (see whatsapp-integration/README.md)
# -- never prefix these with VITE_ or put them in the root .env, that file is bundled to the browser.

WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v23.0
